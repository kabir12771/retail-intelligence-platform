# ============================================================
# Retail Intelligence Platform - Example Environment File
# Copy this file to .env and update values for your machine.
# Do NOT upload your real .env file to GitHub.
# ============================================================

# SQL Server connection
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=RetailIntelligenceDW
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_AUTH_MODE=windows
DB_USERNAME=
DB_PASSWORD=
DB_TRUST_SERVER_CERTIFICATE=yes

# Pipeline configuration
PIPELINE_NAME=Retail Intelligence Platform ETL
PIPELINE_ENV=dev

# ETL behavior
CLEAR_STAGING_BATCH=true
ENABLE_POST_LOAD_VALIDATION=true
VALIDATE_MART_VIEWS=true

# File movement behavior
MOVE_FILES_AFTER_SUCCESS=true
MOVE_REJECTED_FILES_ON_FAILURE=true