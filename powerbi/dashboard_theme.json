{
  "name": "Retail Intelligence Executive Theme",
  "dataColors": [
    "#2563EB",
    "#10B981",
    "#F59E0B",
    "#EF4444",
    "#8B5CF6",
    "#06B6D4",
    "#84CC16",
    "#F97316",
    "#64748B",
    "#111827"
  ],
  "background": "#F8FAFC",
  "foreground": "#111827",
  "tableAccent": "#2563EB",
  "good": "#10B981",
  "neutral": "#F59E0B",
  "bad": "#EF4444",
  "maximum": "#10B981",
  "center": "#F59E0B",
  "minimum": "#EF4444",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 14,
      "color": "#111827"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12,
      "color": "#111827"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#475569"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 28,
      "color": "#111827"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "radius": 8
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#CBD5E1"
              }
            },
            "position": "Outer",
            "preset": "Custom",
            "shadowSpread": 1,
            "shadowBlur": 3,
            "angle": 45,
            "shadowDistance": 1,
            "transparency": 70
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#111827"
              }
            },
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "alignment": "Left",
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#111827"
              }
            },
            "fontSize": 28,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#475569"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": false,
            "gridHorizontal": true,
            "outlineColor": {
              "solid": {
                "color": "#E5E7EB"
              }
            }
          }
        ],
        "columnHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#111827"
              }
            },
            "backColor": {
              "solid": {
                "color": "#F1F5F9"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "values": [
          {
            "fontColor": {
              "solid": {
                "color": "#334155"
              }
            },
            "fontSize": 9,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#334155"
              }
            },
            "textSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "header": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#111827"
              }
            },
            "textSize": 10,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    }
  }
}